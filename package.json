{
  "name": "cs-blog",
  "version": "0.0.0",
  "engines": {
    "node": ">=21.5.0"
  },
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "post:new": "ng g @scullyio/init:post",
    "scully": "npx scully --project cs-blog",
    "preview": "npx scully serve --project cs-blog",
    "clean:site": "sh -c 'if [ -d ./docs ]; then find ./docs -mindepth 1 ! -name CNAME -exec rm -rf {} +; fi'",
    "build:site": "npm run clean:site && npm run build && npm run scully"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.18",
